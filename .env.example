# Create .env.local with your key (never commit .env.local)

# Required for /api/analyze — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Single vision call (gate + extract combined) — defaults to gpt-4o
# OPENAI_MODEL=gpt-4o

# Image detail: low (default, fewer tokens) or high (better for dense labels)
# OPENAI_VISION_DETAIL=low

# Max completion tokens for vision JSON — default 1400
# OPENAI_VISION_MAX_TOKENS=1400

# Age-specific bullets from extracted JSON — defaults to gpt-4o-mini
# OPENAI_MODEL_ADVICE=gpt-4o-mini

# Max tokens for age-advice JSON — default 1200
# OPENAI_ADVICE_MAX_TOKENS=1200

# Daily analyze limit per IP (UTC day). Default 20.
# ANALYZE_DAILY_LIMIT=20

# Set to true to disable the daily limit (admin / testing).
# ANALYZE_LIMIT_DISABLED=false

# Optional: durable quota across serverless instances ([Upstash Redis](https://upstash.com))
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
